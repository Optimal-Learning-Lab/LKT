% Generated by hand for the fast online prototype.
\name{LKTOnlineSimpleAdaptiveEval}
\alias{LKTOnlineSimpleAdaptiveEval}
\title{Evaluate the fast online simple-adaptive objective}
\usage{
LKTOnlineSimpleAdaptiveEval(
  par,
  input,
  clip_epsilon = 1e-06,
  denom_epsilon = 1e-06,
  return_details = FALSE,
  require_native = FALSE
)
}
\arguments{
\item{par}{Numeric vector: intercept, recency beta, logsuc beta,
logitdec beta, recency alpha, logsuc alpha.}
\item{input}{Output from \code{LKTOnlineSimpleAdaptiveInput()}.}
\item{clip_epsilon}{Probability clipping value.}
\item{denom_epsilon}{Denominator stabilizer.}
\item{return_details}{Logical; return predictions and final subject betas.}

\item{require_native}{Logical; stop if the compiled native evaluator is not
loaded.}
}
\value{
Negative log likelihood, or details when requested.
}
\description{
Evaluates the sequential online recency/logsuc simple-adaptive model. When the
native routine is available, the replay is handled by compiled C code; otherwise
the function uses an R reference implementation.
}
