% Generated by hand for the online adaptive model.
\name{OnlineAdaptiveModel}
\alias{OnlineAdaptiveModel}
\alias{FastOnlineSimpleAdaptiveModel}
\title{Define the online adaptive LKT model}
\usage{
OnlineAdaptiveModel(
  alpha_recency_start = 0.03,
  alpha_logsuc_start = 0.05,
  alpha_decay_start = 0.01,
  online_mode = "alpha_only",
  beta_alpha_terms = NULL,
  nonlinear_alpha_terms = character(0),
  alpha_start = NULL,
  alpha_lower = -1,
  alpha_upper = 1,
  nonlinear_lower = 1e-05,
  nonlinear_upper = 0.99999,
  maxit = 100,
  factr = 1e+07,
  require_native = FALSE,
  use_gradient = TRUE
)

FastOnlineSimpleAdaptiveModel(
  alpha_recency_start = 0.03,
  alpha_logsuc_start = 0.05,
  alpha_decay_start = 0.01,
  online_mode = "alpha_only",
  beta_alpha_terms = NULL,
  nonlinear_alpha_terms = character(0),
  alpha_start = NULL,
  alpha_lower = -1,
  alpha_upper = 1,
  nonlinear_lower = 1e-05,
  nonlinear_upper = 0.99999,
  maxit = 100,
  factr = 1e+07,
  require_native = FALSE,
  use_gradient = TRUE
)
}
\arguments{
\item{alpha_recency_start}{Starting value for the recency learning rate.}
\item{alpha_logsuc_start}{Starting value for the logsuc learning rate.}
\item{alpha_decay_start}{Legacy starting value for the recency decay learning
rate.}
\item{online_mode}{Online optimizer mode. \code{"alpha_only"} uses the
generalized adaptive alpha layer. \code{"six_parameter"} and
\code{"decay_alpha"} are legacy compatibility modes.}
\item{beta_alpha_terms}{Coefficient names from \code{model$coefs} whose beta
values should be updated online.}
\item{nonlinear_alpha_terms}{Nonlinear parameter keys formatted as
\code{feature|component|slot}, where slot is \code{para}, \code{parb},
\code{parc}, \code{pard}, or \code{pare}.}
\item{alpha_start}{Optional numeric starting vector for all selected beta and
nonlinear alphas. Defaults to small positive starts.}
\item{alpha_lower}{Scalar or vector lower bounds for alpha optimization.
Signed bounds are allowed.}
\item{alpha_upper}{Scalar or vector upper bounds for alpha optimization.}
\item{nonlinear_lower}{Lower clamp for online nonlinear parameter states.}
\item{nonlinear_upper}{Upper clamp for online nonlinear parameter states.}
\item{maxit}{Maximum optimizer iterations.}
\item{factr}{Optimizer \code{factr} control value.}
\item{require_native}{Logical; stop unless the requested adaptive terms are
supported by a compiled native evaluator. Generalized beta-only adaptation is
native; generalized nonlinear adaptation uses the R evaluator except for the
legacy compiled recency-decay case.}
\item{use_gradient}{Logical; pass the propagated gradient to the optimizer.}
}
\value{
A model adapter suitable for \code{LKT(model = ...)}.
}
\description{
Creates an LKT model adapter that first fits the standard LibLinear model, then
optimizes online learning rates for selected beta coefficients and selected
nonlinear feature parameter slots. Every subject starts from the same global
optimum and then updates only the selected states trial by trial.
}
