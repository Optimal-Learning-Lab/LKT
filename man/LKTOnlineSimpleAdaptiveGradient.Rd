% Generated by hand for the fast online prototype.
\name{LKTOnlineSimpleAdaptiveGradient}
\alias{LKTOnlineSimpleAdaptiveGradient}
\title{Gradient for the fast online simple-adaptive objective}
\usage{
LKTOnlineSimpleAdaptiveGradient(
  par,
  input,
  clip_epsilon = 1e-06,
  denom_epsilon = 1e-06,
  require_native = FALSE
)
}
\arguments{
\item{par}{Numeric vector: intercept, recency beta, logsuc beta,
logitdec beta, recency alpha, logsuc alpha.}
\item{input}{Output from \code{LKTOnlineSimpleAdaptiveInput()}.}
\item{clip_epsilon}{Probability clipping value.}
\item{denom_epsilon}{Denominator stabilizer.}
\item{require_native}{Logical; stop if the compiled native evaluator is not
loaded.}
}
\value{
Gradient of the negative log likelihood.
}
\description{
Propagates derivatives through the subject-level online recency/logsuc updates
for the six-parameter simple-adaptive objective.
}
