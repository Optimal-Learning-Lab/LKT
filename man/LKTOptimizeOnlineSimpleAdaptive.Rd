% Generated by hand for the fast online prototype.
\name{LKTOptimizeOnlineSimpleAdaptive}
\alias{LKTOptimizeOnlineSimpleAdaptive}
\title{Optimize the fast online simple-adaptive model}
\usage{
LKTOptimizeOnlineSimpleAdaptive(
  input,
  start = NULL,
  lower = c(-Inf, -Inf, -Inf, -Inf, 0, 0),
  upper = rep(Inf, 6),
  control = list(maxit = 100),
  require_native = FALSE,
  use_gradient = TRUE
)
}
\arguments{
\item{input}{Output from \code{LKTOnlineSimpleAdaptiveInput()}.}
\item{start}{Optional six-parameter starting vector.}
\item{lower}{Lower bounds for L-BFGS-B.}
\item{upper}{Upper bounds for L-BFGS-B.}
\item{control}{Optimizer control list.}

\item{require_native}{Logical; stop if the compiled native evaluator is not
loaded.}

\item{use_gradient}{Logical; pass the propagated gradient to the optimizer.}
}
\value{
A list containing the optimizer result and fit details.
}
\description{
Optimizes the six-parameter online simple-adaptive model:
intercept, recency beta, logsuc beta, logitdec beta, recency alpha, and logsuc
alpha.
}
